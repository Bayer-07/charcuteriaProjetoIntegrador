# Configurações de Email (Gmail)
# Gere uma senha de aplicativo em: https://myaccount.google.com/apppasswords
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_app

# Configurações de Frete (Melhor Envio)
# Obtenha o token em: https://melhorenvio.com.br/
FRETE_ACCESS_TOKEN=seu_token_melhor_envio
CEP_ORIGEM=seu_cep_origem

